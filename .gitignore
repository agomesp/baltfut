# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# generated at build (prebuild stamps the build id)
/public/version.json

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets; the example template IS committed
.env*
!.env.example

# vercel
.vercel

# local-only admin panel — privileged (service_role); never commit, never deploy
/admin/

# supabase (local stack state / generated, never the migrations)
supabase/.branches
supabase/.temp
supabase/.env

# typescript
*.tsbuildinfo
next-env.d.ts

# promos now live in the Supabase `promos` table; this is just a local-dev fallback
/public/promos.json
