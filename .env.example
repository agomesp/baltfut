# Copy to .env.local and fill in. .env.local is gitignored — NEVER commit secrets.

# ── Frontend (inlined into the static build; PUBLIC by design) ───────────────
# Supabase project URL + the PUBLIC anon key. Safe to expose: Row Level Security
# locks the database down (anon can only read the public vote views). Without
# these the site still shows live scores; voting is simply hidden.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base path for GitHub Pages PROJECT sites (served from /<repo>, e.g. /baltfut).
# Leave empty for local dev, a custom domain, or a user/org page. CI sets this.
NEXT_PUBLIC_BASE_PATH=

# ── Edge Function secrets (SERVER-SIDE ONLY — set via `supabase secrets set`) ─
# Listed for reference; these are NOT frontend env and must never be exposed.
# Salts the IP hash so stored hashes aren't reversible. Generate with:
#   openssl rand -hex 32
VOTE_IP_PEPPER=
# Comma-separated site origins allowed to call the function (CORS allow-list):
#   https://<user>.github.io,http://localhost:3000
ALLOWED_ORIGINS=
# NOTE: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by
# the Supabase platform into the function. Do not set them yourself.
